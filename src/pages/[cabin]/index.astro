---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cabins, cabinMap } from '../../lib/cabins';
import { gen, draw } from '../../lib/sketch';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return cabins.map((c) => ({ params: { cabin: c.key } }));
}

const key = Astro.params.cabin!;
const meta = cabinMap[key];
const notes = await getCollection('notes', (n) => n.data.cabin === key);
const boardLine =
  notes.length > 0
    ? `필기 ${notes.length}장이 분필로 적혀 있음`
    : '아직 분필 자국이 없음 — 곧 첫 필기가';

// 통나무 벽 — 널빤지 이음새를 손그림 선으로
let seams = '';
for (let i = 1; i < 8; i++) {
  seams += draw(
    gen.line(i * 80, 0, i * 80, 300, {
      stroke: '#61492f',
      strokeWidth: 2.2,
      roughness: 2.2,
      bowing: 2.5,
      seed: meta.seed + 40 + i,
    }),
  );
}
// 나무 옹이
function knot(x: number, y: number, w: number, seed: number): string {
  const outer = gen.ellipse(x, y, w, w * 0.62, { stroke: '#61492f', strokeWidth: 1.6, roughness: 1.6, seed });
  const dot = gen.ellipse(x, y, w * 0.35, w * 0.22, { stroke: '#61492f', strokeWidth: 1.3, roughness: 1.4, seed: seed + 1 });
  return draw(outer) + draw(dot);
}
const knots = knot(118, 236, 22, meta.seed + 60) + knot(352, 52, 18, meta.seed + 62) + knot(58, 254, 15, meta.seed + 64);

// 칠판 미리보기 — 손그림 나무 프레임
const boardFrame = gen.rectangle(150, 176, 300, 104, {
  stroke: '#241a12',
  strokeWidth: 3,
  roughness: 1.8,
  bowing: 1.2,
  seed: meta.seed + 70,
});
// 제목 밑줄 — 분필 색 한 획
const nameW = Math.min(430, meta.name.length * 22 + 16);
const titleLine = gen.line(42, 136, 42 + nameW, 139, {
  stroke: '#f2c15a',
  strokeWidth: 2.2,
  roughness: 2.2,
  bowing: 2,
  seed: meta.seed + 72,
});
---

<BaseLayout title={`${meta.name} · choo-studio`}>
  <main class="cabin">
    <div class="cabin-inner">
      <svg viewBox="0 0 640 300" class="scene" xmlns="http://www.w3.org/2000/svg">
        <g fill="#7a5c3e">
          <rect x="0" y="0" width="640" height="300"></rect>
          <rect x="80" y="0" width="80" height="300" fill="#73553a"></rect>
          <rect x="240" y="0" width="80" height="300" fill="#73553a"></rect>
          <rect x="400" y="0" width="80" height="300" fill="#73553a"></rect>
          <rect x="560" y="0" width="80" height="300" fill="#73553a"></rect>
        </g>
        <g set:html={seams + knots} />

        <!-- 램프 — 은은하게 일렁이는 불빛 -->
        <line x1="470" y1="0" x2="470" y2="70" stroke="#3a2c20" stroke-width="2"></line>
        <ellipse class="lamp-halo" cx="470" cy="82" rx="46" ry="32" fill="#f2c15a" opacity="0.16"></ellipse>
        <ellipse class="lamp-glow" cx="470" cy="82" rx="30" ry="20" fill="#f2c15a" opacity="0.9"></ellipse>
        <ellipse cx="470" cy="80" rx="18" ry="12" fill="#fce29a"></ellipse>

        <text x="40" y="120" class="hand" fill="#fbf3e2" font-size="34" font-weight="700">{meta.name}</text>
        <g set:html={draw(titleLine)} />
        <text x="42" y="158" class="hand" fill="#e8d3b0" font-size="17">{meta.intro}</text>

        <a href={`/${key}/board`}>
          <g class="board-preview" transform="rotate(-1.5 300 230)">
            <rect x="150" y="176" width="300" height="104" rx="4" fill="#3a2c20"></rect>
            <rect x="160" y="186" width="280" height="84" fill="#2d453b"></rect>
            <g set:html={draw(boardFrame)} />
            <text x="176" y="214" class="hand" fill="#f2d675" font-size="17">✎ 이 오두막의 칠판</text>
            <text x="176" y="240" class="hand" fill="#cfe0d5" font-size="14">{boardLine}</text>
            <text x="176" y="262" class="hand" fill="#8fae9c" font-size="13">→ 클릭해서 칠판 열기</text>
          </g>
        </a>

        <!-- 고양이 추 — 꼬리 살랑, 가끔 깜빡 -->
        <g transform="translate(548,236)">
          <ellipse cx="0" cy="20" rx="26" ry="9" fill="#000" opacity="0.15"></ellipse>
          <path class="cat-tail" d="M18 14 Q34 6 30 -10" fill="none" stroke="#2b2320" stroke-width="5" stroke-linecap="round"></path>
          <path d="M-18 20 Q-22 -6 -8 -8 Q-10 -22 2 -12 Q14 -22 12 -8 Q26 -6 20 20 Z" fill="#2b2320"></path>
          <polygon points="-12,-8 -18,-22 -6,-12" fill="#2b2320"></polygon>
          <polygon points="10,-8 18,-22 4,-12" fill="#2b2320"></polygon>
          <g class="cat-eyes">
            <circle cx="-6" cy="4" r="2" fill="#f2d675"></circle>
            <circle cx="7" cy="4" r="2" fill="#f2d675"></circle>
          </g>
        </g>
        <text x="512" y="286" class="hand" fill="#d9c3a0" font-size="12">고양이 추</text>
      </svg>

      <a href="/" class="hand back">‹ 숲으로 돌아가기</a>
    </div>
  </main>
</BaseLayout>

<style>
  .cabin {
    min-height: 100vh;
    background: var(--color-wood-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .cabin-inner {
    width: 100%;
    max-width: 940px;
  }
  .scene {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    box-shadow: 0 10px 40px rgba(26, 18, 10, 0.35);
  }
  .scene a {
    cursor: pointer;
  }
  .board-preview {
    transition: opacity 0.2s ease;
  }
  .scene a:hover .board-preview {
    opacity: 0.88;
  }
  .back {
    display: inline-block;
    margin-top: 1rem;
    color: #e6743b;
    font-size: 1.1rem;
    text-decoration: none;
  }
  .back:hover {
    text-decoration: underline wavy;
  }

  /* 램프 불빛 일렁임 */
  .lamp-glow,
  .lamp-halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: flicker 3.4s ease-in-out infinite;
  }
  .lamp-halo {
    animation-duration: 4.1s;
  }
  @keyframes flicker {
    0%, 100% {
      opacity: 0.9;
      transform: scale(1);
    }
    45% {
      opacity: 0.72;
      transform: scale(0.96);
    }
    60% {
      opacity: 0.95;
      transform: scale(1.03);
    }
  }
  .lamp-halo {
    animation-name: flicker-halo;
  }
  @keyframes flicker-halo {
    0%, 100% {
      opacity: 0.16;
      transform: scale(1);
    }
    50% {
      opacity: 0.09;
      transform: scale(0.94);
    }
  }

  /* 고양이 추 — 꼬리 살랑 · 눈 깜빡 */
  .cat-tail {
    transform-box: fill-box;
    transform-origin: left bottom;
    animation: tail-swish 4s ease-in-out infinite;
  }
  @keyframes tail-swish {
    0%, 100% {
      transform: rotate(0deg);
    }
    50% {
      transform: rotate(9deg);
    }
  }
  .cat-eyes {
    transform-box: fill-box;
    transform-origin: center;
    animation: blink 6s ease-in-out infinite;
  }
  @keyframes blink {
    0%, 91%, 96%, 100% {
      transform: scaleY(1);
    }
    93.5% {
      transform: scaleY(0.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lamp-glow,
    .lamp-halo,
    .cat-tail,
    .cat-eyes {
      animation: none;
    }
  }
</style>
