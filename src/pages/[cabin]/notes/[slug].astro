---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { cabinMap } from '../../../lib/cabins';
import { gen, draw } from '../../../lib/sketch';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { cabin: note.data.cabin, slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const key = Astro.params.cabin!;
const meta = cabinMap[key];
const { Content } = await render(note);

// 제목 밑줄 — 오두막 색 색연필 한 획
const titleW = Math.min(560, note.data.title.length * 30 + 40);
const titleLine = gen.line(3, 7, titleW, 10, {
  stroke: meta.color,
  strokeWidth: 2.6,
  roughness: 2.4,
  bowing: 2.5,
  seed: meta.seed + 90,
});
---

<BaseLayout title={`${note.data.title} · choo-studio`}>
  <main class="notebook-room">
    <div class="page">
      <span class="tape tape-left" aria-hidden="true"></span>
      <span class="tape tape-right" aria-hidden="true"></span>
      <a href={`/${key}/board`} class="hand back">‹ 칠판으로</a>
      <h1 class="hand paper-title" style={`color: ${meta.color}`}>{note.data.title}</h1>
      <svg class="title-underline" viewBox={`0 0 ${titleW + 6} 14`} style={`width: ${titleW + 6}px`} aria-hidden="true">
        <g set:html={draw(titleLine)} />
      </svg>
      <p class="hand paper-meta">
        {note.data.date.toLocaleDateString('ko-KR')} · {meta.name}
      </p>
      <article class="notebook-body">
        <Content />
      </article>

      <!-- 고양이 추가 지나간 자국 -->
      <div class="paw-trail" aria-hidden="true">
        <svg viewBox="0 0 120 46" class="paws">
          <g fill="#b9a98a">
            <g transform="translate(8,26) rotate(-18)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
            <g transform="translate(46,12) rotate(6)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
            <g transform="translate(86,28) rotate(24)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
          </g>
        </svg>
        <span class="hand paw-note">… 추 지나감</span>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .notebook-room {
    min-height: 100vh;
    background: var(--color-paper);
    padding: 3rem 2rem;
  }
  .page {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    background: #fbf8ee;
    background-image: repeating-linear-gradient(#fbf8ee 0 31px, var(--color-paper-line) 31px 32px);
    border-left: 26px solid var(--color-paper);
    box-shadow:
      inset 30px 0 0 -28px #d98b8b,
      0 12px 34px rgba(90, 76, 50, 0.16);
    padding: 30px 34px 36px 46px;
  }
  /* 마스킹테이프 */
  .tape {
    position: absolute;
    top: -11px;
    width: 92px;
    height: 26px;
    background: rgba(233, 200, 118, 0.5);
    border-left: 1px dashed rgba(160, 130, 60, 0.35);
    border-right: 1px dashed rgba(160, 130, 60, 0.35);
    box-shadow: 0 1px 3px rgba(90, 76, 50, 0.15);
  }
  .tape-left {
    left: 34px;
    transform: rotate(-5deg);
  }
  .tape-right {
    right: 34px;
    transform: rotate(4deg);
  }
  .back {
    color: #b0a074;
    text-decoration: none;
    font-size: 1rem;
  }
  .back:hover {
    color: #9e4525;
    text-decoration: underline wavy;
  }
  .paper-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0.3rem 0 0;
  }
  .title-underline {
    display: block;
    height: 14px;
    max-width: 100%;
    margin: -3px 0 0;
    opacity: 0.75;
  }
  .paper-meta {
    color: #8a8266;
    margin: 0.15rem 0 1.2rem;
  }
  .paw-trail {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    margin-top: 2.4rem;
    opacity: 0.55;
  }
  .paws {
    width: 110px;
    height: 42px;
  }
  .paw-note {
    color: #a89a78;
    font-size: 0.95rem;
  }
</style>
