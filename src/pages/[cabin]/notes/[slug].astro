---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { cabinMap } from '../../../lib/cabins';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { cabin: note.data.cabin, slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const key = Astro.params.cabin!;
const meta = cabinMap[key];
const { Content } = await render(note);

// 같은 오두막의 다른 필기 (브런치 '추천글'처럼 아래에)
const all = await getCollection('notes');
const others = all
  .filter((n) => n.data.cabin === key && n.id !== note.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<BaseLayout title={`${note.data.title} · choo-studio`}>
  <main class="read-room">
    <article class="read" style={`--accent: ${meta.color}`}>
      <a href={`/${key}/board`} class="back" style={`color: ${meta.color}`}>‹ 칠판으로</a>
      <h1 class="read-title">{note.data.title}</h1>
      <p class="read-meta">
        {note.data.date.toLocaleDateString('ko-KR')} · {meta.name}
      </p>
      <div class="notebook-body">
        <Content />
      </div>

      {others.length > 0 && (
        <nav class="more">
          <p class="more-label">이 오두막의 다른 필기</p>
          <ul>
            {others.map((n) => (
              <li>
                <a href={`/${key}/notes/${n.id}`}>
                  <span class="more-title">{n.data.title}</span>
                  <span class="more-date">{n.data.date.toLocaleDateString('ko-KR')}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <!-- 고양이 추가 지나간 자국 (놀이터의 흔적 하나만 조용히) -->
      <div class="paw-trail" aria-hidden="true">
        <svg viewBox="0 0 120 46" class="paws">
          <g fill="#c8bda6">
            <g transform="translate(8,26) rotate(-18)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
            <g transform="translate(46,12) rotate(6)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
            <g transform="translate(86,28) rotate(24)">
              <ellipse cx="0" cy="4" rx="4.4" ry="3.6" />
              <circle cx="-4.5" cy="-2.5" r="1.7" />
              <circle cx="-1.5" cy="-4.4" r="1.7" />
              <circle cx="1.8" cy="-4.2" r="1.7" />
              <circle cx="4.7" cy="-2" r="1.7" />
            </g>
          </g>
        </svg>
        <span class="hand paw-note">… 추 지나감</span>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .read-room {
    min-height: 100vh;
    background: #efe9dc;
    padding: 3.5rem 1.5rem 4.5rem;
  }
  .read {
    max-width: 788px;
    margin: 0 auto;
    background: #fdfcf8;
    border: 1px solid rgba(120, 100, 60, 0.07);
    border-radius: 14px;
    box-shadow: 0 8px 30px rgba(90, 76, 50, 0.11);
    padding: 42px 44px 34px;
  }
  .back {
    display: inline-block;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 1.6rem;
    opacity: 0.92;
  }
  .back:hover {
    text-decoration: underline;
  }
  .read-title {
    font-size: 2.1rem;
    font-weight: 700;
    line-height: 1.32;
    letter-spacing: -0.01em;
    color: #2e2a24;
    margin: 0 0 0.5rem;
  }
  .read-meta {
    color: #9a927e;
    font-size: 0.9rem;
    margin: 0 0 2.2rem;
  }
  /* 이 오두막의 다른 필기 */
  .more {
    margin-top: 3rem;
    padding-top: 1.6rem;
    border-top: 1px solid #e6ddc9;
  }
  .more-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #9a927e;
    margin: 0 0 0.6rem;
  }
  .more ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .more a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
    text-decoration: none;
    color: #37322a;
    font-size: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid #f1ead8;
  }
  .more li:last-child a {
    border-bottom: none;
  }
  .more a:hover .more-title {
    color: var(--accent);
    text-decoration: underline;
  }
  .more-date {
    color: #b3a98a;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .paw-trail {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    margin-top: 2.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid #f0ead9;
    opacity: 0.5;
  }
  .paws {
    width: 96px;
    height: 38px;
  }
  .paw-note {
    color: #a89a78;
    font-size: 0.9rem;
  }
</style>
