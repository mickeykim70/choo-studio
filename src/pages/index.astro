---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cabin from '../components/Cabin.astro';
import { gen, draw } from '../lib/sketch';

// 오솔길 — 굽이치는 진짜 흙길: (1) 폭 있는 모래색 밴드 + (2) 그 위 디딤돌 점선
const trailPts: [number, number][] = [
  [24, 548],
  [120, 470],
  [250, 360],
  [390, 332],
  [530, 342],
  [650, 320],
  [726, 352],
];
const roadBand = gen.curve(trailPts, { stroke: '#d9c49c', strokeWidth: 28, roughness: 1.5, bowing: 1.3, seed: 7 });
const roadEdge = gen.curve(trailPts, { stroke: '#c3aa78', strokeWidth: 30, roughness: 1.7, bowing: 1.4, seed: 8 });
const roadDots = gen.curve(trailPts, { stroke: '#9a8352', strokeWidth: 4, roughness: 1.1, seed: 9 });

// 나무 — 캐노피(원) + 몸통(선). d=지름
function tree(cx: number, cy: number, d: number, seed: number): string {
  const canopy = gen.circle(cx, cy, d, {
    stroke: '#6f8a5c', strokeWidth: 2, fill: '#bcd6ac', fillStyle: 'solid', roughness: 1.7, seed,
  });
  const trunk = gen.line(cx, cy + d / 2, cx, cy + d / 2 + Math.max(14, d * 0.3), {
    stroke: '#6f8a5c', strokeWidth: 3, roughness: 1.2, seed: seed + 1,
  });
  return draw(canopy) + draw(trunk);
}

// 덤불 — 낮게 퍼진 타원
function bush(cx: number, cy: number, w: number, seed: number): string {
  const b = gen.ellipse(cx, cy, w, w * 0.55, {
    stroke: '#7d9a68', strokeWidth: 1.8, fill: '#cadfba', fillStyle: 'solid', roughness: 1.8, seed,
  });
  return draw(b);
}

// 풀 포기 — 짧은 선 세 가닥
function grass(x: number, y: number, seed: number): string {
  const a = gen.line(x, y, x - 4, y - 11, { stroke: '#8aa76e', strokeWidth: 2, roughness: 1.4, seed });
  const b = gen.line(x + 4, y, x + 4, y - 13, { stroke: '#8aa76e', strokeWidth: 2, roughness: 1.4, seed: seed + 1 });
  const c = gen.line(x + 8, y, x + 13, y - 10, { stroke: '#8aa76e', strokeWidth: 2, roughness: 1.4, seed: seed + 2 });
  return draw(a) + draw(b) + draw(c);
}

// 들꽃 — 작은 꽃송이 + 줄기
function flower(x: number, y: number, color: string, seed: number): string {
  const stem = gen.line(x, y + 3, x, y + 13, { stroke: '#8aa76e', strokeWidth: 1.6, roughness: 1.3, seed: seed + 1 });
  const bloom = gen.circle(x, y, 9, { stroke: color, strokeWidth: 1.5, fill: color, fillStyle: 'solid', roughness: 1.3, seed });
  return draw(stem) + draw(bloom);
}

// 길가 돌멩이
function stone(x: number, y: number, w: number, seed: number): string {
  const s = gen.ellipse(x, y, w, w * 0.6, {
    stroke: '#a89e88', strokeWidth: 1.5, fill: '#d6cdb8', fillStyle: 'solid', roughness: 1.6, seed,
  });
  return draw(s);
}

const trees =
  tree(395, 210, 72, 21) +
  tree(455, 405, 56, 23) +
  tree(330, 118, 46, 25) +
  tree(710, 205, 54, 27) +
  tree(52, 345, 48, 29) +
  tree(352, 586, 40, 31);

const bushes = bush(180, 322, 52, 41) + bush(655, 296, 44, 43) + bush(680, 560, 58, 45) + bush(255, 470, 40, 47);

const grasses =
  grass(140, 528, 51) + grass(320, 300, 54) + grass(575, 388, 57) + grass(90, 415, 60) +
  grass(700, 300, 63) + grass(430, 465, 66) + grass(30, 240, 69);

const flowers =
  flower(158, 512, '#e8a0b4', 71) + flower(345, 288, '#f2d675', 73) +
  flower(600, 395, '#e8a0b4', 75) + flower(72, 428, '#c9a7e0', 77) + flower(448, 452, '#f2d675', 79);

const stones = stone(200, 415, 18, 81) + stone(475, 322, 14, 83) + stone(620, 348, 16, 85);

// 해 — 오른쪽 위, 살 6개
const sunBody = gen.circle(722, 52, 44, {
  stroke: '#d9a441', strokeWidth: 2, fill: '#f7dd8a', fillStyle: 'solid', roughness: 1.5, seed: 91,
});
let sunRays = '';
const rayAngles = [-160, -120, -80, -35, 155, 115];
rayAngles.forEach((deg, i) => {
  const rad = (deg * Math.PI) / 180;
  const x1 = 722 + Math.cos(rad) * 30;
  const y1 = 52 + Math.sin(rad) * 30;
  const x2 = 722 + Math.cos(rad) * 42;
  const y2 = 52 + Math.sin(rad) * 42;
  sunRays += draw(gen.line(x1, y1, x2, y2, { stroke: '#d9a441', strokeWidth: 2, roughness: 1.3, seed: 92 + i }));
});

// 제목 밑줄 — 색연필 한 획
const titleLine = gen.line(28, 55, 342, 58, { stroke: '#c0562f', strokeWidth: 2.5, roughness: 2.2, bowing: 2, seed: 5 });

// 지름길 팻말 (판 + 다리)
const sign = gen.rectangle(286, 495, 146, 30, { stroke: '#b39b6e', strokeWidth: 2, fill: '#f7efd9', fillStyle: 'solid', roughness: 1.4, seed: 31 });
const signLeg = gen.line(359, 525, 359, 545, { stroke: '#b39b6e', strokeWidth: 3, roughness: 1.3, seed: 32 });
---

<BaseLayout title="choo-studio · 숲속 오두막 강의동">
  <main class="home">
    <svg viewBox="0 0 780 620" class="map" xmlns="http://www.w3.org/2000/svg">
      <text x="28" y="46" class="hand" fill="#3a352c" font-size="27" font-weight="700"
        >choo-studio 숲속 강의동 ✎</text>
      <g set:html={draw(titleLine)} />
      <text x="30" y="78" class="hand" fill="#7a7259" font-size="16"
        >— 마음 가는 오두막으로 들어가세요 (청강생: 나)</text>

      <g set:html={draw(sunBody) + sunRays} />

      <g set:html={draw(roadEdge) + draw(roadBand) + draw(roadDots, { dash: '2 16' })} />
      <g set:html={stones} />
      <g set:html={bushes + trees} />
      <g set:html={grasses + flowers} />

      <!-- 흩날리는 나뭇잎 -->
      <g class="leaves" fill="#9fbd8a">
        <ellipse class="leaf l1" cx="410" cy="240" rx="5" ry="2.6" />
        <ellipse class="leaf l2" cx="700" cy="240" rx="4.5" ry="2.4" />
        <ellipse class="leaf l3" cx="340" cy="150" rx="4" ry="2.2" />
      </g>

      <Cabin x={70} y={120} color="#3f6f9f" roofFill="#cfe0ef" label="안경 · 눈 관" seed={101} href="/eyes" />
      <Cabin x={500} y={90} color="#4a7a5a" roofFill="#d2e6d6" label="수학 · 물리 관" seed={202} icon="∫ π" href="/math" soon />
      <Cabin x={150} y={440} color="#7a6aab" roofFill="#e0daf0" label="AI 관" seed={303} icon="◈" href="/ai" soon />
      <Cabin x={520} y={440} color="#c0562f" roofFill="#f2ddc9" label="잡담 정자" seed={404} href="/talk" soon />

      <a href="/eyes/board">
        <g class="signpost">
          <g set:html={draw(signLeg) + draw(sign)} />
          <text x="359" y="515" text-anchor="middle" class="hand" fill="#9e4525" font-size="14" font-weight="700"
            >↗ 최근 필기 바로가기</text>
        </g>
      </a>

      <text x="40" y="556" class="hand" fill="#9e4525" font-size="16" font-weight="700">입구 ▶</text>
    </svg>
  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
    background:
      radial-gradient(ellipse 90% 60% at 50% -10%, #fdf8e9 0%, transparent 60%),
      var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .map {
    width: 100%;
    max-width: 1080px;
    height: auto;
  }
  .signpost {
    cursor: pointer;
    transition: transform 0.25s ease;
    transform-box: fill-box;
    transform-origin: center bottom;
  }
  a:hover .signpost {
    transform: rotate(-2deg) translateY(-2px);
  }

  /* 흩날리는 나뭇잎 — 아주 천천히, 은은하게 */
  .leaf {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: drift 11s ease-in-out infinite;
  }
  .leaf.l2 {
    animation-duration: 14s;
    animation-delay: 4s;
  }
  .leaf.l3 {
    animation-duration: 12.5s;
    animation-delay: 8s;
  }
  @keyframes drift {
    0% {
      opacity: 0;
      transform: translate(0, 0) rotate(0deg);
    }
    12% {
      opacity: 0.75;
    }
    70% {
      opacity: 0.55;
    }
    100% {
      opacity: 0;
      transform: translate(-34px, 84px) rotate(230deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .leaf {
      animation: none;
    }
  }
</style>
